{
  "name": "goodreads-cli-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm --filter @zaydiscold/goodreads-cli build && pnpm --filter @zaydiscold/goodreads-mcp build",
    "test": "pnpm test:cli && pnpm test:mcp",
    "test:cli": "pnpm --filter @zaydiscold/goodreads-cli test",
    "test:mcp": "pnpm --filter @zaydiscold/goodreads-mcp test",
    "typecheck": "pnpm --filter @zaydiscold/goodreads-cli typecheck && pnpm --filter @zaydiscold/goodreads-cli build && pnpm --filter @zaydiscold/goodreads-mcp typecheck",
    "lint": "eslint cli/src cli/test mcp/src mcp/test",
    "lint:fix": "eslint cli/src cli/test mcp/src mcp/test --fix",
    "format": "prettier --write cli/src cli/test mcp/src mcp/test scripts",
    "format:check": "prettier --check cli/src cli/test mcp/src mcp/test scripts",
    "cli": "pnpm --filter @zaydiscold/goodreads-cli cli",
    "mcp": "scripts/goodreads-mcp.sh",
    "doctor": "node scripts/goodreads-doctor.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
